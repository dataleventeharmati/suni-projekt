from __future__ import annotations

from pathlib import Path
import pandas as pd
import pyarrow.parquet as pq

DATA = Path("data/processed/tch_repairs_cleaned.parquet")
OUT_DIR = Path("reports/campaign_detector")
OUT_DIR.mkdir(parents=True, exist_ok=True)

# --- CONFIG (easy to tweak) ---
DATE_COL = "RECEIVED_DATE"
DIMENSIONS = [
    "PRODUCT_CODE",
    "SHIP_TO_COUNTRY",
    "SOLD_TO_CUSTOMER_NAME",
    "FAILURE_CODE_1",
    "REPAIR_CODE_1",
]
MIN_GROUP_TOTAL = 200          # ignore tiny groups overall
MIN_MONTH_COUNT = 30           # ignore tiny monthly buckets
TOP_N = 50                     # output size


def load_minimal() -> pd.DataFrame:
    cols = [DATE_COL] + DIMENSIONS
    df = pq.read_table(DATA.as_posix(), columns=cols).to_pandas()

    # keep only valid dates
    df = df[df[DATE_COL].notna()].copy()
    df["year_month"] = df[DATE_COL].dt.to_period("M").astype(str)

    # fill missing dims to keep grouping stable
    for c in DIMENSIONS:
        if c in df.columns:
            df[c] = df[c].fillna("(missing)").astype(str)

    return df


def detect_spikes(df: pd.DataFrame) -> pd.DataFrame:
    # Group by dimensions + month
    g = (
        df.groupby(DIMENSIONS + ["year_month"], dropna=False)
          .size()
          .rename("count")
          .reset_index()
    )

    # total per group (across all months)
    totals = (
        g.groupby(DIMENSIONS, dropna=False)["count"]
         .sum()
         .rename("group_total")
         .reset_index()
    )

    g = g.merge(totals, on=DIMENSIONS, how="left")

    # filter small groups / months
    g = g[(g["group_total"] >= MIN_GROUP_TOTAL) & (g["count"] >= MIN_MONTH_COUNT)].copy()

    # baseline: previous months average within the same group
    g = g.sort_values(DIMENSIONS + ["year_month"])
    g["prev_mean"] = (
        g.groupby(DIMENSIONS, dropna=False)["count"]
         .apply(lambda s: s.shift(1).expanding().mean())
         .reset_index(level=list(range(len(DIMENSIONS))), drop=True)
    )

    # spike score: ratio vs previous mean
    g["spike_ratio"] = g["count"] / g["prev_mean"]
    g["spike_ratio"] = g["spike_ratio"].replace([pd.NA, pd.NaT, float("inf")], pd.NA)

    # also store delta
    g["spike_delta"] = g["count"] - g["prev_mean"]

    # keep only where we have a baseline
    g = g[g["prev_mean"].notna()].copy()

    # rank by ratio primarily, then delta
    g = g.sort_values(["spike_ratio", "spike_delta"], ascending=[False, False])

    return g


def main():
    print("Loading data...")


# --- DATE FILTER (project rule): keep data from 2025-01-01 onwards
START_DATE = pd.Timestamp("2025-01-01")
if "RECEIVED_DATE" in df.columns:
    before = len(df)
    df = df[df["RECEIVED_DATE"].notna() & (df["RECEIVED_DATE"] >= START_DATE)].copy()
    print(f"Date filter applied (>= {START_DATE.date()}): {before:,} -> {len(df):,}")
# --------------------------------------------------------------

    df = load_minimal()
    print(f"Rows: {len(df):,}")

    print("Detecting spikes...")
    spikes = detect_spikes(df)

    out_csv = OUT_DIR / "campaign_spikes_top.csv"
    spikes.head(TOP_N).to_csv(out_csv, index=False)

    # also export a full list (can be large, but still manageable)
    out_all = OUT_DIR / "campaign_spikes_all.csv"
    spikes.to_csv(out_all, index=False)

    # quick console summary
    print("\n=== Campaign Detector (Top 10) ===")
    show = spikes.head(10)[DIMENSIONS + ["year_month", "count", "prev_mean", "spike_ratio", "spike_delta", "group_total"]]
    print(show.to_string(index=False))

    print("\nSaved:")
    print(" -", out_csv.as_posix())
    print(" -", out_all.as_posix())


if __name__ == "__main__":
    main()
